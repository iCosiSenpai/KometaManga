# KometaManga environment variables
#
# WARNING: Any variable set here will OVERRIDE the corresponding value
# in application.yml AND BLOCK changes to that field from the web UI.
# Only set variables you want to manage exclusively from Docker/compose.
#
# Recommended: Use the web UI for all app configuration.
# Only use env vars for infrastructure you want locked (e.g., Komga credentials).
#
# Copy this file to .env and uncomment the variables you need:
#   cp .env.example .env

# --- Komga connection (uncomment to lock from UI) ---
# KOMF_KOMGA_BASE_URI=http://komga:25600
# KOMF_KOMGA_USER=your-email@example.org
# KOMF_KOMGA_PASSWORD=your-password

# --- Server (uncomment to lock from UI) ---
# KOMF_SERVER_PORT=8085
# KOMF_LOG_LEVEL=INFO

# --- Timezone ---
TZ=Europe/Rome

# --- Notifications (optional, uncomment to lock from UI) ---
# KOMF_DISCORD_WEBHOOKS=https://discord.com/api/webhooks/xxx/yyy
# KOMF_APPRISE_URLS=tgram://bottoken/ChatID

# --- Metadata provider API keys (optional, uncomment to lock from UI) ---
# KOMF_METADATA_PROVIDERS_MAL_CLIENT_ID=
# KOMF_METADATA_PROVIDERS_COMIC_VINE_API_KEY=
# KOMF_METADATA_PROVIDERS_BANGUMI_TOKEN=

# --- Timezone ---
TZ=Europe/Rome
